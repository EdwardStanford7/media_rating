{
  "name": "media-rating-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsr generate && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply media-rating --local",
    "db:migrate:remote": "wrangler d1 migrations apply media-rating --remote",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "better-auth": "latest",
    "exceljs": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "latest",
    "@cloudflare/workers-types": "latest",
    "@tanstack/router-cli": "^1.167.9",
    "@types/node": "latest",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
